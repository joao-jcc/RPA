# ==============================================
# Application Configuration
# ==============================================
PROJECT_NAME=RPA API
DESCRIPTION=API for RPA data collection
VERSION=1.0.0
API_PREFIX=/api
ENVIRONMENT=local

# RPA
RPA_HEADLESS=True
RPA_DOWNLOADS_DIR=./app/services/rpa/downloads

# Google
GOOGLE_CLIENT_SECRETS_PATH=./app/services/google/credentials/client_secret.json
GOOGLE_TOKEN_PATH=./app/services/google/credentials/token.json
GOOGLE_DRIVE_FOLDER_NAME=rpa-data
